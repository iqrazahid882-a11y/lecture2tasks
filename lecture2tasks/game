<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Cute Neon Snake</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@500;800;900&family=Rajdhani:wght@500;600;700&display=swap');
        :root { --bg-dark: #1a1a2e; --pastel-blue: #89cff0; --pastel-lavender: #e6e6fa; --pastel-pink: #ffb6c1; --soft-cream: #fffdd0; --panel-bg: rgba(255, 255, 255, 0.1); }
        * { box-sizing: border-box; margin: 0; padding: 0; user-select: none; }
        body { background-color: var(--bg-dark); font-family: 'Rajdhani', sans-serif; color: white; min-height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: center; overflow: hidden; padding: 12px; }
        .game-container { width: 100%; max-width: 440px; position: relative; }
        .viewport-wrapper { position: relative; width: 100%; aspect-ratio: 1; border-radius: 30px; border: 4px solid var(--pastel-pink); overflow: hidden; background: #16213e; }
        canvas { width: 100%; height: 100%; display: block; }
        .overlay { position: absolute; inset: 0; background: rgba(26, 26, 46, 0.9); display: flex; flex-direction: column; align-items: center; justify-content: center; z-index: 10; opacity: 0; pointer-events: none; transition: 0.3s; }
        .overlay.visible { opacity: 1; pointer-events: auto; }
        .action-btn { background: var(--pastel-pink); color: white; border: none; padding: 12px 32px; font-family: 'Orbitron', sans-serif; font-weight: 700; border-radius: 20px; cursor: pointer; text-transform: uppercase; margin: 10px; box-shadow: 0 4px 15px rgba(255, 182, 193, 0.4); }
        .hud-display { display: flex; justify-content: space-between; padding: 12px; background: var(--panel-bg); border-radius: 20px; margin-bottom: 10px; font-size: 1.1em; backdrop-filter: blur(5px); }
    </style>
</head>
<body>
    <div class="game-container">
        <div class="hud-display">
            <span>Score: <b id="score">0</b></span>
            <span>Best: <b id="best-score">0</b></span>
            <span>Diamonds: <b id="diamonds-val">0</b></span>
        </div>
        <div class="viewport-wrapper">
            <canvas id="gameSpace" width="400" height="400"></canvas>
            <div class="overlay visible" id="start-overlay">
                <h2 style="color:var(--pastel-pink)">CUTE SNAKE</h2>
                <button class="action-btn" id="start-btn">START GAME</button>
            </div>
            <div class="overlay" id="death-overlay">
                <h2 style="color:var(--pastel-blue)">OOPS! CRASHED</h2>
                <button class="action-btn" id="shop-btn">GHOST MODE (5💎)</button>
                <button class="action-btn" id="reboot-btn">REBOOT</button>
            </div>
        </div>
    </div>

    <script>
        const canvas = document.getElementById('gameSpace');
        const ctx = canvas.getContext('2d');
        const gap = 20;
        let snake = [{x: 120, y: 200}, {x: 100, y: 200}, {x: 80, y: 200}], food = {x: 200, y: 200}, diamond = null;
        let particles = [], hurdles = [], powerUp = null;
        let powerUpTimer = 0, currentSpeed = 125, scoreMultiplier = 1, lastScoreMilestone = 0;
        let diamondCurrency = parseInt(localStorage.getItem('neonSnake_diamonds')) || 0;
        let bestScore = parseInt(localStorage.getItem('neonSnake_bestScore')) || 0;
        let score = 0, isDead = false, isGhostMode = false, ghostTimer = 0, isGameStarted = false;
        let dx = gap, dy = 0, nextDx = gap, nextDy = 0;

        document.getElementById('diamonds-val').textContent = diamondCurrency;
        document.getElementById('best-score').textContent = bestScore;
        
        document.getElementById('start-btn').onclick = () => { isGameStarted = true; document.getElementById('start-overlay').classList.remove('visible'); };
        document.getElementById('reboot-btn').onclick = () => location.reload();
        document.getElementById('shop-btn').onclick = () => {
            if (diamondCurrency >= 5) {
                diamondCurrency -= 5;
                localStorage.setItem('neonSnake_diamonds', diamondCurrency);
                document.getElementById('diamonds-val').textContent = diamondCurrency;
                isGhostMode = true; ghostTimer = 50; isDead = false;
                document.getElementById('death-overlay').classList.remove('visible');
            } else alert("Not enough diamonds!");
        };

        function processGridPhysics() {
            if (!isGameStarted || isDead) return;
            if (isGhostMode) { ghostTimer--; if (ghostTimer <= 0) isGhostMode = false; }
            if (powerUpTimer > 0) { powerUpTimer--; if (powerUpTimer === 0) { currentSpeed = 125; scoreMultiplier = 1; } }

            if (score > 0 && score % 100 === 0 && score !== lastScoreMilestone) {
                for(let i=0; i<3; i++) hurdles.push({x: Math.floor(Math.random()*20)*gap, y: Math.floor(Math.random()*20)*gap});
                lastScoreMilestone = score;
                if(Math.random() < 0.3) powerUp = {x: Math.floor(Math.random()*20)*gap, y: Math.floor(Math.random()*20)*gap, type: Math.random() < 0.5 ? 'speed' : 'slow'};
            }

            dx = nextDx; dy = nextDy;
            const head = { x: snake[0].x + dx, y: snake[0].y + dy };

            if (!isGhostMode && (head.x < 0 || head.x >= 400 || head.y < 0 || head.y >= 400 || snake.some(s => s.x === head.x && s.y === head.y) || hurdles.some(h => h.x === head.x && h.y === head.y))) {
                isDead = true;
                if (score > bestScore) { bestScore = score; localStorage.setItem('neonSnake_bestScore', bestScore); document.getElementById('best-score').textContent = bestScore; }
                document.getElementById('death-overlay').classList.add('visible'); return;
            }
            
            snake.unshift(head);
            if (head.x === food.x && head.y === food.y) {
                score += (10 * scoreMultiplier); document.getElementById('score').textContent = score;
                for(let i=0; i<8; i++) particles.push({x: food.x+10, y: food.y+10, vx: (Math.random()-0.5)*10, vy: (Math.random()-0.5)*10, alpha: 1});
                food = {x: Math.floor(Math.random()*20)*gap, y: Math.floor(Math.random()*20)*gap};
                if(Math.random() < 0.5) diamond = {x: Math.floor(Math.random()*20)*gap, y: Math.floor(Math.random()*20)*gap};
            } else snake.pop();

            if (powerUp && head.x === powerUp.x && head.y === powerUp.y) {
                powerUpTimer = 40; if (powerUp.type === 'speed') { currentSpeed = 60; scoreMultiplier = 2; } else { currentSpeed = 250; }
                powerUp = null;
            }

            if (diamond && head.x === diamond.x && head.y === diamond.y) {
                diamondCurrency++; document.getElementById('diamonds-val').textContent = diamondCurrency;
                localStorage.setItem('neonSnake_diamonds', diamondCurrency); diamond = null;
            }
        }

        function draw() {
            ctx.fillStyle = '#16213e'; ctx.fillRect(0,0,400,400);
            
            // Draw Hurdles
            ctx.fillStyle = '#fffdd0';
            hurdles.forEach(h => { ctx.beginPath(); ctx.roundRect(h.x+2, h.y+2, gap-4, gap-4, 5); ctx.fill(); });
            
            // Draw Snake
            snake.forEach((s, i) => {
                ctx.globalAlpha = isGhostMode ? 0.4 : 1.0;
                ctx.fillStyle = (i === 0) ? '#89cff0' : '#e6e6fa';
                ctx.beginPath(); ctx.arc(s.x + gap/2, s.y + gap/2, gap/2 - 2, 0, Math.PI*2); ctx.fill();
            });

            // Draw Food & Diamond & Powerups
            ctx.font = "16px Arial"; ctx.textAlign = "center"; ctx.textBaseline = "middle";
            ctx.fillText("🍎", food.x + gap/2, food.y + gap/2);
            if(diamond) ctx.fillText("💎", diamond.x + gap/2, diamond.y + gap/2);
            if(powerUp) { ctx.fillStyle = powerUp.type === 'speed' ? '#00ff00' : '#0000ff'; ctx.beginPath(); ctx.arc(powerUp.x + gap/2, powerUp.y + gap/2, 6, 0, Math.PI*2); ctx.fill(); }

            // Particles
            particles.forEach((p, index) => {
                p.x += p.vx; p.y += p.vy; p.alpha -= 0.05;
                if(p.alpha <= 0) particles.splice(index, 1);
                else { ctx.globalAlpha = p.alpha; ctx.fillStyle = '#ffb6c1'; ctx.fillRect(p.x, p.y, 4, 4); }
            });
            ctx.globalAlpha = 1.0;
        }

        function gameLoop() { processGridPhysics(); draw(); setTimeout(gameLoop, currentSpeed); }
        window.onkeydown = e => {
            const d = {ArrowUp:[0,-gap], ArrowDown:[0,gap], ArrowLeft:[-gap,0], ArrowRight:[gap,0]}[e.key];
            if(d) { nextDx = d[0]; nextDy = d[1]; }
        };
        gameLoop();
    </script>
</body>
</html>
